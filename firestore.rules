rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tihiledurgesh@gmail.com" && request.auth.token.email_verified == true));
    }

    // Hardware Tasks Collection
    match /hardware_tasks/{taskId} {
      // Allow authenticated users to create and read tasks
      allow read, create: if isAuthenticated();
      // Allow updates if authenticated (hardware or app)
      allow update: if isAuthenticated();
      // Only admins can delete tasks
      allow delete: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
